pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'todo-app'
        DOCKER_TAG   = "${BUILD_NUMBER}"
        K8S_NAMESPACE = 'default'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Current branch: ${env.BRANCH_NAME}"
            }
        }

        stage('Test') {
            steps {
                dir('app') {
                    sh 'pip install -r requirements.txt'
                    sh 'python -m pytest tests/ -v --junitxml=reports/junit.xml'
                }
            }
            post {
                always {
                    junit 'app/reports/junit.xml'
                }
            }
        }

        stage('Build & Push') {
            steps {
                sh """
                    docker build \
                        -t ${DOCKER_IMAGE}:${DOCKER_TAG} \
                        -t ${DOCKER_IMAGE}:latest \
                        -f docker/Dockerfile .
                """
                // 推送到镜像仓库（按需配置）
                // sh "docker push ${DOCKER_IMAGE}:${DOCKER_TAG}"
                // sh "docker push ${DOCKER_IMAGE}:latest"
            }
        }

        stage('Deploy to K8s') {
            steps {
                sh """
                    kubectl set image deployment/todo-app \
                        app=${DOCKER_IMAGE}:${DOCKER_TAG} \
                        -n ${K8S_NAMESPACE} --record
                """
                sh "kubectl rollout status deployment/todo-app -n ${K8S_NAMESPACE} --timeout=120s"
            }
        }
    }

    post {
        success {
            echo 'Pipeline 执行成功！'
        }
        failure {
            echo 'Pipeline 执行失败，请检查日志。'
        }
        always {
            cleanWs()
        }
    }
}